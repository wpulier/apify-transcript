{
  "openapi": "3.0.0",
  "info": {
    "title": "Large Video to Transcript Standby API",
    "version": "1.0.0",
    "description": "Submit a video/audio file or direct media URL and receive a job page with transcript artifacts when complete."
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Open the submit page",
        "responses": {
          "200": {
            "description": "HTML submit page"
          }
        }
      }
    },
    "/jobs": {
      "post": {
        "summary": "Create a transcript job",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["mediaUrl"],
                    "properties": {
                      "mediaUrl": {
                        "type": "string",
                        "format": "uri"
                      }
                    }
                  },
                  {
                    "type": "object",
                    "required": ["fileName", "fileSize"],
                    "properties": {
                      "fileName": {
                        "type": "string"
                      },
                      "fileSize": {
                        "type": "integer",
                        "minimum": 1
                      },
                      "contentType": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}/status": {
      "get": {
        "summary": "Get job status",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current job status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}/chunks/{index}": {
      "put": {
        "summary": "Upload one media chunk",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chunk accepted"
          }
        }
      }
    },
    "/jobs/{jobId}/complete": {
      "post": {
        "summary": "Finalize upload and start transcription",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Worker run started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "summary": "Open the job page",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "HTML job page"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "JobResponse": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "jobUrl": {
            "type": "string",
            "format": "uri"
          },
          "job": {
            "$ref": "#/components/schemas/Job"
          }
        }
      },
      "JobStatusResponse": {
        "type": "object",
        "properties": {
          "job": {
            "$ref": "#/components/schemas/Job"
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["created", "uploading", "queued", "processing", "completed", "failed"]
          },
          "message": {
            "type": "string"
          },
          "runUrl": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "artifactUrls": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
